# ── Dependencies ────────────────────────────────
node_modules/
web/node_modules/

# ── Build output ─────────────────────────────────
dist/
web/dist/

# ── Environment / secrets ────────────────────────
.env
.env.local
.env.*.local

# ── Prisma ───────────────────────────────────────
# Keep schema.prisma and seed.ts tracked; ignore generated client
# (regenerated by `prisma generate` after npm i)
node_modules/.prisma/

# ── Logs ─────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor ──────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.suo
*.user

# ── TypeScript ───────────────────────────────────
*.tsbuildinfo

# ── k6 results ───────────────────────────────────
# Commit summary charts to README instead of raw output files
k6-results*.json
