// TransitOps — schema.prisma
// Section 5 (Master Data + Transactional + Supporting models)
// Section 7 (partial unique indexes as @@index with where clause via raw migration)
// FROZEN after Hour 1 — only M1 edits this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VehicleType {
  TRUCK
  VAN
  PICKUP
  BIKE
  BUS
}

enum FuelType {
  DIESEL
  PETROL
  CNG
  EV
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum LicenseCategory {
  LMV
  HMV
  TRANS
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  SERVICE
  REPAIR
  INSPECTION
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseType {
  TOLL
  PARKING
  FINE
  OTHER
}

enum NotificationType {
  LICENSE_EXPIRING
  FUEL_ANOMALY
  MAINTENANCE_DUE
  TRIP_STATUS
  ROLE_ASSIGNED
}

// ─────────────────────────────────────────────
// 5.1 MASTER DATA
// ─────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role?      // null = pending approval (Section 3)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Vehicle {
  id                   String        @id @default(cuid())
  registrationNumber   String        @unique  // Rule #1 — DB constraint
  name                 String
  model                String?
  type                 VehicleType
  fuelType             FuelType
  maxLoadCapacityKg    Float         // > 0 enforced by Zod + CHECK
  odometerKm           Float         @default(0) // monotonic — only increases
  serviceIntervalKm    Int           @default(10000)
  acquisitionCost      Float         // > 0; ROI denominator
  region               String?
  status               VehicleStatus @default(AVAILABLE)
  // Computed fields — updated by service layer, stored for query performance
  kmSinceLastServiceKm Float         @default(0)
  avgKmPerLiter        Float?        // null until ≥1 completed trip; EV stays null

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model Driver {
  id                String          @id @default(cuid())
  name              String
  licenseNumber     String          @unique
  licenseCategory   LicenseCategory
  licenseExpiryDate DateTime
  contactNumber     String?
  safetyScore       Int             @default(80) // 0–100; auto-adjusted by service
  status            DriverStatus    @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips Trip[]

  @@map("drivers")
}

model EmissionFactor {
  id             String   @id @default(cuid())
  fuelType       FuelType @unique
  kgCo2PerLiter  Float    // DIESEL 2.68, PETROL 2.31, CNG 2.02, EV 0
  source         String   @default("DEFRA 2024")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("emission_factors")
}

// Settings key-value store (Section 4)
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // stored as JSON string — parse in service layer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────
// 5.2 TRANSACTIONAL DATA
// ─────────────────────────────────────────────

model Trip {
  id                String     @id @default(cuid())
  // TR-2026-NNNN generated by service layer (sequence logic in application)
  code              String     @unique
  source            String
  destination       String
  vehicleId         String
  driverId          String
  cargoWeightKg     Float      // > 0; ≤ vehicle.maxLoadCapacityKg (Rule #5)
  plannedDistanceKm Float      // > 0
  revenue           Float      @default(0)
  status            TripStatus @default(DRAFT)
  dispatchedAt      DateTime?
  completedAt       DateTime?
  startOdometerKm   Float?     // set at dispatch = vehicle.odometerKm
  endOdometerKm     Float?     // entered at completion; must be > start
  actualDistanceKm  Float?     // computed: end − start, stored
  fuelUsedL         Float?     // entered at completion; auto-creates FuelLog
  co2Kg             Float?     // computed stored: fuelUsedL × emissionFactor
  idempotencyKey    String?    @unique // double-click guard (Section 7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver    @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
  expenses Expense[]

  // Section 7 partial unique indexes — defined as raw SQL migration
  // because Prisma does not natively support partial unique indexes via schema syntax.
  // Migration file: prisma/migrations/manual_partial_indexes.sql
  // CREATE UNIQUE INDEX one_active_trip_per_vehicle ON trips(vehicle_id) WHERE status = 'DISPATCHED';
  // CREATE UNIQUE INDEX one_active_trip_per_driver  ON trips(driver_id)  WHERE status = 'DISPATCHED';

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@map("trips")
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String
  type        MaintenanceType
  description String
  cost        Float             @default(0) // ≥ 0; editable until CLOSED
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now())
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  // Partial unique index: one OPEN log per vehicle
  // CREATE UNIQUE INDEX one_open_maintenance_per_vehicle ON maintenance_logs(vehicle_id) WHERE status = 'OPEN';
  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id              String   @id @default(cuid())
  vehicleId       String
  tripId          String?  // nullable; auto-set when created from trip completion
  liters          Float    // > 0
  cost            Float    // ≥ 0
  date            DateTime @default(now())
  // Anomaly fields (Section 9) — computed and stored for explainability
  expectedLiters  Float?   // actualDistanceKm / avgKmPerLiter at time of log
  deviationPct    Float?   // (liters − expectedLiters) / expectedLiters
  isAnomaly       Boolean  @default(false)
  anomalyReviewed Boolean  @default(false)
  reviewNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
  @@index([isAnomaly])
  @@index([date])
  @@map("fuel_logs")
}

model Expense {
  id        String      @id @default(cuid())
  vehicleId String
  tripId    String?
  type      ExpenseType
  amount    Float       // > 0
  date      DateTime    @default(now())
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
  @@index([date])
  @@map("expenses")
}

// ─────────────────────────────────────────────
// 5.3 SUPPORTING MODELS
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String   // SCREAMING_SNAKE_CASE, past tense — e.g. TRIP_DISPATCHED
  entity    String   // model name — e.g. "Trip"
  entityId  String
  payload   Json
  timestamp DateTime @default(now())

  // Immutable — no updatedAt, no update/delete API
  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@map("notifications")
}
